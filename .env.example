# ─── Frontend (Vite) — also set in Vercel → Project → Settings → Environment Variables
# Must be your PUBLIC backend URL (not localhost). No trailing slash.
VITE_API_URL=https://your-backend.onrender.com/api

# ─── Backend (server/.env) — on Render/Railway/etc.
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/streamvault
JWT_SECRET=your_super_secret_jwt_key
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
PORT=5000
# Exact Vercel URL (no trailing slash)
CLIENT_URL=https://streamvault-wheat-three.vercel.app
